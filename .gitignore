# -----------------------------
# Local/Server non-sync files
# -----------------------------

# Environment secrets
.env
.env.*
!.env.example
!**/.env.example

# Python cache/runtime
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual envs
.venv/
venv/
env/

# Logs and temp files
*.log
logs/
*.pid
*.tmp

# Node/Vite build artifacts
node_modules/
dist/
dist-ssr/

# IDE and OS files
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Runtime data volumes (do not sync)
mysql_data/
qdrant_storage/

# Local databases/backups
*.db
*.sqlite3
*.sql

