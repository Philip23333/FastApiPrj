# =========================
# MyNews Backend Env Example
# =========================

# Runtime
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8080

# Database
DATABASE_URL=mysql+aiomysql://root:123456@127.0.0.1:3306/news_app?charset=utf8mb4
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO=false

# Redis (prefer REDIS_URL in production)
REDIS_URL=
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_CONNECT_TIMEOUT=1
REDIS_SOCKET_TIMEOUT=0.2

# JWT
JWT_SECRET_KEY=replace-with-at-least-32-chars-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS (comma-separated list, e.g. https://news.example.com,https://www.news.example.com)
CORS_ALLOW_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# AI (OpenAI-compatible chat completions)
AI_ENABLED=True
AI_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_API_KEY=sk-7e592be8e195429ea85075f5c5fe49cc
AI_MODEL=qwen3.6-plus
AI_TIMEOUT_SECONDS=30

# RAG
AI_EMBEDDING_MODEL=text-embedding-v4
AI_EMBEDDING_TIMEOUT_SECONDS=30
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=80
RAG_EMBED_BATCH_SIZE=6
RAG_QDRANT_COLLECTION=mynews_rag
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=
